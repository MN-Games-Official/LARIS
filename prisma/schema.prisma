// Polaris Pilot - Prisma Schema
// MySQL Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER MODEL
// ============================================================
model User {
  id                Int                 @id @default(autoincrement())
  email             String              @unique @db.VarChar(255)
  username          String              @unique @db.VarChar(50)
  password_hash     String              @db.VarChar(255)
  full_name         String?             @db.VarChar(100)
  avatar_url        String?             @db.VarChar(500)
  email_verified    Boolean             @default(false)
  email_verified_at DateTime?
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt

  // Relations
  applications      Application[]
  rankCenters       RankCenter[]
  apiKeys           ApiKey[]
  passwordResets    PasswordReset[]
  emailVerifications EmailVerification[]

  @@map("users")
}

// ============================================================
// API KEY MODEL
// ============================================================
model ApiKey {
  id          Int       @id @default(autoincrement())
  user_id     Int
  type        String    @db.VarChar(20) // "roblox" | "polaris"
  name        String?   @db.VarChar(100)
  encrypted_key String  @db.Text
  key_prefix  String    @db.VarChar(30) // For display
  scopes      String?   @db.Text       // JSON array of scopes
  last_used   DateTime?
  expires_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  is_active   Boolean   @default(true)

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([type])
  @@map("api_keys")
}

// ============================================================
// APPLICATION MODEL
// ============================================================
model Application {
  id              String    @id @default(uuid())
  user_id         Int
  name            String    @db.VarChar(100)
  description     String?   @db.Text
  group_id        String    @db.VarChar(30)
  target_role     String    @db.VarChar(100) // "rank: 218" or "groups/x/roles/y"
  pass_score      Int       @default(70)
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  // Style
  primary_color   String    @default("#ff4b6e") @db.VarChar(20)
  secondary_color String    @default("#1f2933") @db.VarChar(20)

  // Data serialization (stored as JSON strings)
  questions_json  String    @db.LongText
  style_json      String?   @db.LongText

  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  submissions     ApplicationSubmission[]

  @@index([user_id])
  @@index([group_id])
  @@map("applications")
}

// ============================================================
// RANK CENTER MODEL
// ============================================================
model RankCenter {
  id          String    @id @default(uuid())
  user_id     Int
  name        String    @db.VarChar(100)
  group_id    String    @db.VarChar(30)
  universe_id String?   @db.VarChar(30)
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  // Data serialization
  ranks_json  String    @db.LongText

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([group_id])
  @@map("rank_centers")
}

// ============================================================
// APPLICATION SUBMISSION MODEL
// ============================================================
model ApplicationSubmission {
  id                String    @id @default(uuid())
  application_id    String
  roblox_user_id    String    @db.VarChar(30)
  membership_id     String?   @db.VarChar(100)
  answers_json      String    @db.LongText
  score             Float
  max_score         Float
  passed            Boolean
  feedback          String?   @db.Text
  promotion_status  String?   @db.VarChar(20) // "pending" | "success" | "failed"
  submitted_at      DateTime  @default(now())

  application       Application @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@index([application_id])
  @@index([roblox_user_id])
  @@map("application_submissions")
}

// ============================================================
// PASSWORD RESET MODEL
// ============================================================
model PasswordReset {
  id          String    @id @default(uuid())
  user_id     Int
  token       String    @unique @db.VarChar(255)
  expires_at  DateTime
  used        Boolean   @default(false)
  created_at  DateTime  @default(now())

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_resets")
}

// ============================================================
// EMAIL VERIFICATION MODEL
// ============================================================
model EmailVerification {
  id          String    @id @default(uuid())
  user_id     Int
  token       String    @unique @db.VarChar(255)
  expires_at  DateTime
  used        Boolean   @default(false)
  created_at  DateTime  @default(now())

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("email_verifications")
}
